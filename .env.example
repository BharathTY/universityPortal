# PostgreSQL (Prisma)
DATABASE_URL="postgresql://postgres:TestAdmin@103.182.211.219:5432/university_portal?schema=public"

# JWT signing (minimum 32 characters)
JWT_SECRET="change-me-to-a-long-random-secret-at-least-32-chars"

# Public URL for invite links in emails (no trailing slash)
NEXT_PUBLIC_APP_URL="http://localhost:7777"

# Default role slug for first-time sign-in (must exist in DB / seed)
DEFAULT_ROLE_SLUG=student

# In development, OTP is also returned by the API and shown on the login / verify screens.
# In production, set to "true" only for demos/staging (never expose OTP publicly on real sites).
# SHOW_OTP_ON_SCREEN=false

# Show demo account shortcuts on /login (still requires seeded DB). Default: on in development only.
# NEXT_PUBLIC_SHOW_DEMO_LOGINS=true

# SMTP (optional — in development OTP is logged to the console if unset)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=register@qspiders.com
SMTP_PASS=rzuk sdqk pcqm gqix
EMAIL_FROM=register@qspiders.com

# Optional (recommended if your SMTP provider requires it)
# SMTP_SECURE=false           # set true for port 465
# SMTP_REQUIRE_TLS=true       # for providers that insist on STARTTLS

# Seed / demo accounts — full table: docs/DEMO_LOGINS.md
# Master: master@university.local | Admin: admin@university.local | University: university@university.local
# Counsellor: counsellor@university.local | Consultant: consultant@university.local
# Students: student@ … student6@ @university.local (see doc for counsellor vs consultant link)
SEED_COUNSELLOR_EMAIL=counsellor@university.local
SEED_CONSULTANT_EMAIL=consultant@university.local

# Comma-separated origins/hosts — merged into next.config.ts `allowedDevOrigins` (dev HMR over LAN/public IP).
ALLOWED_DEV_ORIGINS=http://103.182.211.219:7777

# Razorpay (optional — student application uses Checkout when both are set; otherwise simulated pay in dev)
# RAZORPAY_KEY_ID=rzp_test_xxxx
# RAZORPAY_KEY_SECRET=xxxx